# ==============================================================================
# CDC Dedup Engine 核心环境变量配置说明
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 基础服务配置 (Basic Server Config)
# ------------------------------------------------------------------------------
# HTTP API 监听端口，用于前端看板请求与数据交互
PORT=8080

# ------------------------------------------------------------------------------
# 2. 本地持久化与元数据存储 (Local Storage & Metadata DB)
# ------------------------------------------------------------------------------
# 本地 CAS (内容寻址存储) 根目录及 SQLite 索引文件存放路径
DATA_DIR=./data

# ------------------------------------------------------------------------------
# 3. CDC 内容定义切块算法约束配置 (Content-Defined Chunking Constraints)
# ------------------------------------------------------------------------------
# 最小分块字节数约束 (默认: 16 KB = 16 * 1024)
MIN_CHUNK_SIZE=16384

# 目标平均分块字节数约束 (默认: 64 KB = 64 * 1024)
AVG_CHUNK_SIZE=65536

# 最大分块字节数约束 (默认: 256 KB = 256 * 1024)
MAX_CHUNK_SIZE=262144

# ------------------------------------------------------------------------------
# 4. 远端云端对象存储配置 (Cloud Object Storage - 兼容阿里云 OSS)
# ------------------------------------------------------------------------------
# 阿里云 OSS 访问域名 (地域节点 Endpoint)
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 阿里云 RAM 访问控制密钥 ID (AccessKey ID)
OSS_ACCESS_KEY_ID=your_access_key_id

# 阿里云 RAM 访问控制密钥安全码 (AccessKey Secret)
OSS_ACCESS_KEY_SECRET=your_access_key_secret

# 阿里云 OSS 存储桶名称 (Bucket Name)
OSS_BUCKET_NAME=your_bucket_name
