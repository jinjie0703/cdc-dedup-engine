# ==========================================
# CDC Dedup Engine Backend Environment Config
# ==========================================

# HTTP API 服务监听端口
PORT=8080

# 本地 CAS 存储与 SQLite 索引数据目录
DATA_DIR=./data

# 分块大小约束配置 (Bytes)
MIN_CHUNK_SIZE=16384
AVG_CHUNK_SIZE=65536
MAX_CHUNK_SIZE=262144

# ==========================================
# 云原生远端对象存储扩展配置 (可选配置)
# ==========================================
COS_ENDPOINT=
COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=
